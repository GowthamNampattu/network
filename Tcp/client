#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <sys/socket.h>

#define BUFFER_SIZE 1024

int main() {
    char *ip = "127.0.0.1";
    int port;
    int sock;
    struct sockaddr_in addr;
    char buffer[BUFFER_SIZE];

    // 1. Create Socket
    sock = socket(AF_INET, SOCK_STREAM, 0);
    if (sock < 0){
        perror("[-]Socket error");
        exit(1);
    }
    printf("[+]TCP client socket created.\n");

    // 2. Input Port
    printf("Enter the Port number to connect to: ");
    scanf("%d", &port);
    // CRITICAL: Clear input buffer to remove newline from scanf
    while ((getchar()) != '\n'); 

    memset(&addr, '\0', sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    addr.sin_addr.s_addr = inet_addr(ip);

    // 3. Connect
    if (connect(sock, (struct sockaddr*)&addr, sizeof(addr)) < 0){
        perror("[-]Connection error");
        exit(1);
    }
    printf("[+]Connected to the server.\n");

    // 4. Chat Loop (Ping-Pong: Client speaks first)
    while(1){
        // --- STEP A: Client types a message ---
        memset(buffer, 0, BUFFER_SIZE);
        printf("Client (You): ");
        fgets(buffer, BUFFER_SIZE, stdin);
        
        // Remove trailing newline
        buffer[strcspn(buffer, "\n")] = 0; 

        // Send to Server
        send(sock, buffer, strlen(buffer), 0);

        // Check if Client typed "exit"
        if (strcmp(buffer, "exit") == 0) {
            printf("[+]Exit command sent. Disconnecting.\n");
            close(sock);
            exit(0);
        }

        // --- STEP B: Wait for Server response ---
        memset(buffer, 0, BUFFER_SIZE);
        printf("Waiting for Server...\n");
        
        if (recv(sock, buffer, BUFFER_SIZE - 1, 0) <= 0) {
             printf("[-]Server disconnected.\n");
             break;
        }

        // Check if Server said "exit"
        if (strcmp(buffer, "exit") == 0) {
            printf("[!] Server requested exit. Disconnecting.\n");
            close(sock);
            exit(0);
        }

        printf("Server: %s\n", buffer);
    }

    close(sock);
    return 0;
}
