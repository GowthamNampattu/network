#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <sys/socket.h>

#define BUFFER_SIZE 1024

int main() {
    char *ip = "127.0.0.1";
    int port;
    int sock;
    struct sockaddr_in server_addr;
    char buffer[BUFFER_SIZE];
    socklen_t addr_size;

    
    sock = socket(AF_INET, SOCK_DGRAM, 0);
    if (sock < 0){
        perror("[-]Socket error");
        exit(1);
    }
    printf("[+]UDP client socket created.\n");

   
    printf("Enter the Port number to send to: ");
    scanf("%d", &port);
    while ((getchar()) != '\n');

    memset(&server_addr, '\0', sizeof(server_addr));
    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(port);
    server_addr.sin_addr.s_addr = inet_addr(ip);

 
    while(1){
   
        memset(buffer, 0, BUFFER_SIZE);
        printf("Client (You): ");
        fgets(buffer, BUFFER_SIZE, stdin);
        buffer[strcspn(buffer, "\n")] = 0;

      
        sendto(sock, buffer, strlen(buffer), 0, (struct sockaddr*)&server_addr, sizeof(server_addr));

       
        if (strcmp(buffer, "exit") == 0) {
            printf("[+]Exit command sent. Disconnecting.\n");
            close(sock);
            exit(0);
        }

     
        memset(buffer, 0, BUFFER_SIZE);
        printf("Waiting for Server...\n");
        addr_size = sizeof(server_addr);
        
        int n = recvfrom(sock, buffer, BUFFER_SIZE, 0, (struct sockaddr*)&server_addr, &addr_size);
        
        if (n < 0) {
            printf("[-]Error receiving data.\n");
            break;
        }

       
 
        if (strcmp(buffer, "exit") == 0) {
            printf("[!] Server requested exit. Disconnecting.\n");
            close(sock);
            exit(0);
        }

        printf("Server: %s\n", buffer);
    }

    close(sock);
    return 0;
}
