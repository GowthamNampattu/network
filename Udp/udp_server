#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>

#define BUFFER_SIZE 256

int main()
{
    char BUFFER[BUFFER_SIZE];
    int sockfd;
    int PORT;

    printf("Enter Port Number: ");
    scanf("%d", &PORT);
    getchar();

    sockfd = socket(AF_INET, SOCK_DGRAM, 0);
    if (sockfd == -1)
    {
        perror("Socket");
        return 1;
    }

    struct sockaddr_in server_address, client_address;
    socklen_t addr_size = sizeof(client_address);

    memset(&server_address, 0, sizeof(server_address));
    server_address.sin_family = AF_INET;
    server_address.sin_port = htons(PORT);
    server_address.sin_addr.s_addr = INADDR_ANY;

    if (bind(sockfd, (struct sockaddr*)&server_address, sizeof(server_address)) == -1)
    {
        perror("Bind");
        return 1;
    }

    printf("UDP Server is running...\n");

    while (1)
    {
        int recvcheck = recvfrom(sockfd, BUFFER, BUFFER_SIZE, 0,
                                 (struct sockaddr*)&client_address, &addr_size);

        if (recvcheck <= 0)
            continue;

        // Client exit, server continues
        if (strncasecmp(BUFFER, "exit", 4) == 0)
        {
            printf("Client has exited. Waiting for new client...\n");
            continue; // don't break
        }

        printf("Client: %s", BUFFER);

        printf("Server: ");
        fgets(BUFFER, BUFFER_SIZE, stdin);

        sendto(sockfd, BUFFER, BUFFER_SIZE, 0,
               (struct sockaddr*)&client_address, addr_size);

        // Server exit, notify client and break
        if (strncasecmp(BUFFER, "exit", 4) == 0)
        {
            printf("Server exiting. Notifying client...\n");
            sendto(sockfd, BUFFER, BUFFER_SIZE, 0,
                   (struct sockaddr*)&client_address, addr_size);
            break;
        }
    }

    close(sockfd);
    return 0;
}
